{
    "layer": "top",
    "position": "bottom",
    "height": 16,

    "modules-left": [
        "sway/workspaces",
        "tray",
        "privacy",
        "sway/mode",
        "sway/window"
    ],

    "modules-right": [
        "idle_inhibitor",
        "network",
        "bluetooth",
        "memory",
        "cpu",
        "pulseaudio",
        "temperature",
        "battery",
        "clock#date",
        "clock#time"
    ],

    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "+BATTERY: {capacity}%",
        "format-discharging": "-BATTERY: {capacity}%",
        "tooltip": true
    },

    "clock#time": {
        "interval": 1,
        "format": "{:%r}",
        "tooltip": false
    },

    "clock#date": {
      "interval": 10,
      "format": "{:%b%e,%Y}", // Icon: calendar-alt
      "tooltip-format": "{:%B %e %Y}"
    },

    "cpu": {
        "interval": 5,
        "format": "CPU: {usage}% ({load})", // Icon: microchip
        "states": {
          "warning": 70,
          "critical": 90
        }
    },

    "memory": {
        "interval": 5,
        "format": "RAM: {}%", // Icon: memory
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "network": {
        "interval": 5,
        "format-wifi": "{essid} ({signalStrength}%)", // Icon: wifi
        "format-ethernet": "{ifname}: {ipaddr}/{cidr}", // Icon: ethernet
        "format-disconnected": "NO NETWORK",
        "tooltip-format": "{ifname}: {ipaddr}",
	"on-click-right": "foot nmtui"
    },

    "sway/mode": {
        "format": "<span style=\"italic\">MODE: {}</span>", // Icon: expand-arrows-alt
        "tooltip": false
    },

    "sway/window": {
        "format": "{}",
        "max-length": 20
    },

    "sway/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": "{name}",
    },

    "pulseaudio": {
        "scroll-step": 1,
        "format": "VOL: {volume}%",
        "format-bluetooth": "VOL: {volume}%",
        "format-muted": "MUTED",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
	"on-click-right": "pavucontrol"
    },

    "temperature": {
      "critical-threshold": 60,
      "interval": 5,
      "format": "TEMP: {temperatureC}°C",
      "tooltip": true
    },

    "idle_inhibitor": {
       "format": "{icon}",
       "format-icons": {
           "activated": "NON-IDLE",
           "deactivated": "SLEEPY"
       }
    },

    "bluetooth": {
	"format": "BLUETOOTH",
	"format-connected": "{device_alias}",
	"format-connected-battery": "{device_alias} {device_battery_percentage}%",
	"tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
	"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
  	"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "foot bluetoothctl",
	"on-click-right" : "foot bluetui"
    },

    "privacy": {
        "icon-spacing": 4,
        "icon-size": 18,
        "transition-duration": 250,
        "modules": [
            {
                "type": "screenshare",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-out",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-in",
                "tooltip": true,
                "tooltip-icon-size": 24
            }
        ],
        "ignore-monitor": true,
    },

    "tray": {
        "icon-size": 16,
        "spacing": 16
    }

}
